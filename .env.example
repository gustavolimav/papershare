# Copy this file to .env.development.local and fill in real values.
# See infra/env.ts for which of these are required vs. optional at
# startup, and CLAUDE.md's "Environment variables" table for what each
# one does.

# --- Required ---

# Postgres connection (local Docker Compose defaults shown)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=local_user
POSTGRES_DB=local_db
POSTGRES_PASSWORD=local_password

# One-way pepper mixed into every password hash — never change in prod,
# or every existing password stops verifying.
PEPPER=change-me-to-a-long-random-string

# S3-compatible storage (MinIO locally; real AWS S3/R2 credentials in prod)
STORAGE_BUCKET=papershare-dev
STORAGE_ACCESS_KEY_ID=local_storage_user
STORAGE_SECRET_ACCESS_KEY=local_storage_password

# --- Optional (each feature degrades gracefully when unset) ---

# Full Postgres connection string — not read directly by app code today,
# kept for compatibility with tooling that expects it.
DATABASE_URL=postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DB

# 32-byte hex key for AES-256-GCM — without it, saving a per-user AI key
# in Settings fails with a clear "unavailable" error instead of crashing.
ENCRYPTION_KEY=

# Shared secret for the x-migrations-secret header on /api/v1/migrations
# — without it, only a logged-in superadmin session can run migrations.
MIGRATIONS_SECRET=

# S3-compatible storage — extra options, only needed for MinIO/non-AWS
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# Max upload size in MB — defaults to 50 if unset
MAX_FILE_SIZE_MB=50

# Transactional email (view notifications, password reset) — unset makes
# the mailer a silent no-op
RESEND_API_KEY=
MAIL_FROM_ADDRESS=

# Stripe billing — unset makes checkout/portal routes return 503
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
